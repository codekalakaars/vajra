import { VerticalBox, HorizontalBox, Button } from "std-widgets.slint";

export component AppWindow inherits Window {
    in-out property <string> project-dir: "";
    in-out property <string> status-text: "Ready";
    callback quit();

    VerticalBox {
        spacing: 10px;

        Text {
            text: "Vajra Sandbox";
            font-size: 24px;
            font-weight: 700;
        }

        Text {
            text: "Directory: " + root.project-dir;
            font-size: 14px;
            color: #666;
        }

        Text {
            text: "Status: " + root.status-text;
            font-size: 14px;
            color: #888;
        }

        HorizontalBox {
            spacing: 10px;

            Button {
                text: "Quit";
                clicked => { root.quit(); }
            }
        }
    }
}
